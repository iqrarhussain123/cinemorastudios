# Copy to .env.local

# From Google Cloud Console > APIs & Services > Credentials (OAuth Client ID, type "Web application").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only used by `npm run get-token` (one-time local setup) — must match the redirect URI
# registered on the OAuth Client ID in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3939/oauth2callback

# Printed by `npm run get-token` after you complete the Google consent screen once. This is the
# only secret the running app needs — it's exchanged for a short-lived access token on every
# request, so it never needs a database or manual rotation.
GOOGLE_REFRESH_TOKEN=
